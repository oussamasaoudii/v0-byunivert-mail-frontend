# Byunivert Mail - Environment Variables Template
# Copy this file to .env.local and fill in the actual values

# Backend API Configuration
# NEXT_PUBLIC_API_URL=http://localhost:3001
# API_SECRET_KEY=your-secret-key-here

# Email Provider (Choose one)
# IMAP Configuration (for future integration)
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=your-email@example.com
# IMAP_PASSWORD=your-password

# SMTP Configuration (for outgoing mail)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password

# Roundcube Integration (optional)
# ROUNDCUBE_URL=http://webmail.example.com
# ROUNDCUBE_API_KEY=your-api-key

# Feature Flags
# NEXT_PUBLIC_ENABLE_RICH_TEXT=true
# NEXT_PUBLIC_ENABLE_ENCRYPTION=false

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
